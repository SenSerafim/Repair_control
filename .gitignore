*.log

# Local env files — committed .env.example only
.env
.env.dev
.env.prod
.env.local
.env.test
.env.staging

# mobile/assets/env/.env.* содержат только публичные values (API URL,
# VAPID public key, flavor). Коммитим для воспроизводимости dev-сборки.
!mobile/assets/env/.env.dev
!mobile/assets/env/.env.staging
!mobile/assets/env/.env.prod

# Secrets — Firebase Admin SDK key, APNs .p8, etc.
backend/secrets/
*-firebase-adminsdk-*.json
*.p8

