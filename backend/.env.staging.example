# Copy to .env.staging перед запуском docker compose -f ... -f docker-compose.staging.yml up
POSTGRES_DB=repair_control
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ChangeMe-StrongPass-32chars-min!

JWT_ACCESS_SECRET=staging_access_secret_change_me_in_vault_32chars_min
JWT_REFRESH_SECRET=staging_refresh_secret_change_me_in_vault_32chars_min

# Selectel Object Storage (S3-совместимое) — prod.
MINIO_ENDPOINT=s3.ru-7.storage.selcloud.ru
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=ChangeMeSelectelAccessKey
MINIO_SECRET_KEY=ChangeMeSelectelSecretKey
MINIO_BUCKET=repair-bucket-test
MINIO_PRESIGN_TTL_SECONDS=300
MINIO_REGION=ru-7
# false → presigned URL вида https://<bucket>.s3.ru-7.storage.selcloud.ru/<key>.
# Обязательно для Selectel: CORS-заголовки выдаются ТОЛЬКО на virtual-hosted
# адрес. Mobile dio работает и с path-style, но admin-web без CORS не сможет
# подгрузить превью документов.
MINIO_PATH_STYLE=false

SENTRY_DSN=
LOG_LEVEL=info
# LOG_PRETTY=true обязателен для non-TTY (docker logs) — без него
# pino-transport блокирует stdout при bufferLogs=true и NestJS висит silent.
LOG_PRETTY=true
METRICS_TOKEN=staging-metrics-secret-32chars-min

FCM_ENABLED=true
FCM_PROJECT_ID=repaircontrol-22bd3
FCM_CLIENT_EMAIL=firebase-adminsdk-fbsvc@repaircontrol-22bd3.iam.gserviceaccount.com
# Multiline private_key: переносы экранировать как \n, обернуть в двойные кавычки.
# Лучше: хранить в Vault / AWS Secrets Manager, а в .env.staging подгружать oneline.
FCM_PRIVATE_KEY=""

SUPPORT_TELEGRAM_URL=https://t.me/repaircontrol_support

API_PORT=3000
ADMIN_PORT=8080
ADMIN_API_URL=http://api:3000

API_IMAGE_TAG=staging
ADMIN_IMAGE_TAG=staging
