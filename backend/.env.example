NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/repair_control?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

BCRYPT_COST=12

SMS_PROVIDER=stub
SMS_API_KEY=
# При SMS_PROVIDER=stub: 4–6-значный фиксированный код для recovery.
SMS_STUB_CODE=123456

# S3 хранилище. Для prod — Selectel Object Storage (ru-7),
# для dev — локальный MinIO через docker-compose.
#
# Selectel (prod):
#   MINIO_ENDPOINT=s3.ru-7.storage.selcloud.ru
#   MINIO_PORT=443
#   MINIO_USE_SSL=true
#   MINIO_REGION=ru-7
#
# MinIO local (dev):
#   MINIO_ENDPOINT=localhost
#   MINIO_PORT=9000
#   MINIO_USE_SSL=false
#   MINIO_REGION=us-east-1
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=repair-control
MINIO_PRESIGN_TTL_SECONDS=300
MINIO_REGION=us-east-1
MINIO_PATH_STYLE=true

FILE_MAX_SIZE_MB=25
FILE_ALLOWED_MIMES=image/jpeg,image/png,application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.wordprocessingml.document

RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_LOGIN_BLOCK_SECONDS=300

RECOVERY_MAX_ATTEMPTS=3
RECOVERY_BLOCK_SECONDS=300

# S5 — Observability
SENTRY_DSN=
LOG_LEVEL=info
LOG_PRETTY=true
METRICS_TOKEN=

# S5 — FCM push (firebase-admin).
# Service Account JSON: Firebase Console → Project Settings → Service accounts
#   → Generate new private key → скачать JSON (положить в backend/secrets/).
# PRIVATE_KEY переносы: экранируйте как \n, обернуть в двойные кавычки.
FCM_ENABLED=false
FCM_PROJECT_ID=repaircontrol-22bd3
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# S5 — Export jobs
EXPORT_TEMP_DIR=/tmp/repair-control-exports
PDF_LOGO_URL=
ZIP_MAX_SIZE_MB=500

# S5 — Admin / support
SUPPORT_TELEGRAM_URL=https://t.me/repaircontrol_support

# S5 — WebSocket
WS_CORS_ORIGIN=*
WS_PING_INTERVAL_MS=25000
WS_PING_TIMEOUT_MS=20000
