{
  "name": "repair-control-backend",
  "version": "0.1.0",
  "description": "Repair Control backend — NestJS monorepo (apps/api + libs)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/apps/api/main",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "lint:check": "eslint \"{apps,libs}/**/*.ts\"",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch --config jest.config.js",
    "test:cov": "jest --coverage --config jest.config.js",
    "test:e2e": "jest --runInBand --config apps/api/test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed:staging": "ts-node prisma/seed-staging.ts",
    "openapi:export": "ts-node -r tsconfig-paths/register scripts/export-openapi.ts",
    "postman:export": "ts-node -r tsconfig-paths/register scripts/export-postman.ts",
    "prepare": "cd .. && git config --local core.hooksPath backend/.husky || true"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nestjs/bullmq": "10.2.1",
    "@nestjs/common": "10.4.4",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.4.4",
    "@nestjs/event-emitter": "2.0.4",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.4",
    "@nestjs/platform-socket.io": "10.4.4",
    "@nestjs/schedule": "4.1.1",
    "@nestjs/swagger": "7.4.2",
    "@nestjs/websockets": "10.4.4",
    "@prisma/client": "5.20.0",
    "@sentry/node": "8.30.0",
    "@socket.io/redis-adapter": "8.3.0",
    "@sparticuz/chromium": "129.0.0",
    "archiver": "7.0.1",
    "bcrypt": "5.1.1",
    "bullmq": "5.12.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "1.4.7",
    "dayjs": "1.11.13",
    "dotenv": "^17.4.2",
    "firebase-admin": "12.5.0",
    "helmet": "8.0.0",
    "ioredis": "5.4.1",
    "joi": "17.13.3",
    "minio": "8.0.1",
    "nanoid": "3.3.7",
    "nestjs-pino": "4.1.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pino": "9.4.0",
    "pino-http": "10.3.0",
    "pino-pretty": "11.2.2",
    "prom-client": "15.1.3",
    "puppeteer-core": "23.5.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "sharp": "0.33.5",
    "socket.io": "4.7.5"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.5",
    "@nestjs/schematics": "10.1.4",
    "@nestjs/testing": "10.4.4",
    "@types/archiver": "6.0.2",
    "@types/bcrypt": "5.0.2",
    "@types/cookie-parser": "1.4.7",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.13",
    "@types/node": "20.16.10",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "3.3.3",
    "prisma": "5.20.0",
    "socket.io-client": "4.7.5",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.6.2"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
